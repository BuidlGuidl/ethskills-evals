+// SPDX-License-Identifier: MIT
+pragma solidity 0.8.28;
+
+import {Script, console2} from "forge-std/Script.sol";
+import {FreelanceEscrow} from "../src/FreelanceEscrow.sol";
+
+/**
+ * @notice Deploys FreelanceEscrow against the canonical USDC of the current chain.
+ *
+ * Env:
+ *   OWNER    fee recipient and fee admin. Defaults to the broadcasting address.
+ *   FEE_BPS  protocol fee in basis points, 0-500. Defaults to 100 (1%).
+ *   TOKEN    override the payment token. Optional; required on unlisted chains.
+ */
+contract Deploy is Script {
+    function run() external returns (FreelanceEscrow escrow) {
+        address token = vm.envOr("TOKEN", _usdc(block.chainid));
+        require(token != address(0), "no USDC for this chain: set TOKEN");
+
+        uint256 fee = vm.envOr("FEE_BPS", uint256(100));
+        address owner = vm.envOr("OWNER", msg.sender);
+
+        vm.startBroadcast();
+        escrow = new FreelanceEscrow(token, owner, uint16(fee));
+        vm.stopBroadcast();
+
+        console2.log("chainId  ", block.chainid);
+        console2.log("escrow   ", address(escrow));
+        console2.log("token    ", token);
+        console2.log("owner    ", owner);
+        console2.log("feeBps   ", fee);
+    }
+
+    function _usdc(uint256 chainId) internal pure returns (address) {
+        if (chainId == 1) return 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48; // Ethereum
+        if (chainId == 8453) return 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913; // Base
+        if (chainId == 42161) return 0xaf88d065e77c8cC2239327C5EDb3A432268e5831; // Arbitrum One
+        if (chainId == 10) return 0x0b2C639c533813f4Aa9D7837CAf62653d097Ff85; // Optimism
+        if (chainId == 11155111) return 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238; // Sepolia
+        if (chainId == 84532) return 0x036CbD53842c5426634e7929541eC2318f3dCF7e; // Base Sepolia
+        return address(0);
+    }
+}
