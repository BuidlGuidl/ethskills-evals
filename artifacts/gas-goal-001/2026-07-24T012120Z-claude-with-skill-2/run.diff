+// SPDX-License-Identifier: MIT
+pragma solidity 0.8.28;
+
+import {Test} from "forge-std/Test.sol";
+import {FreelanceEscrow} from "../src/FreelanceEscrow.sol";
+import {MockUSDC} from "./mocks/MockUSDC.sol";
+
+contract FreelanceEscrowTest is Test {
+    FreelanceEscrow escrow;
+    MockUSDC usdc;
+
+    address owner = makeAddr("owner");
+    address client = makeAddr("client");
+    address freelancer = makeAddr("freelancer");
+    address arbiter = makeAddr("arbiter");
+    address stranger = makeAddr("stranger");
+
+    uint256 constant AMOUNT = 10_000e6; // $10,000 USDC
+    uint16 constant FEE_BPS = 100; // 1%
+    uint32 constant REVIEW = 7 days;
+
+    function setUp() public {
+        usdc = new MockUSDC();
+        escrow = new FreelanceEscrow(address(usdc), owner, FEE_BPS);
+        usdc.mint(client, 1_000_000e6);
+        vm.prank(client);
+        usdc.approve(address(escrow), type(uint256).max);
+        vm.warp(1_800_000_000);
+    }
+
+    function _create() internal returns (uint256 id) {
+        vm.prank(client);
+        id = escrow.createJob(freelancer, arbiter, AMOUNT, uint40(block.timestamp + 30 days), REVIEW);
+    }
+
+    // ------------------------------------------------------------- happy path
+
+    function test_CreateJobEscrowsFunds() public {
+        uint256 id = _create();
+        assertEq(usdc.balanceOf(address(escrow)), AMOUNT);
+        assertEq(usdc.balanceOf(client), 1_000_000e6 - AMOUNT);
+
+        FreelanceEscrow.Job memory job = escrow.getJob(id);
+        assertEq(job.client, client);
+        assertEq(job.freelancer, freelancer);
+        assertEq(job.arbiter, arbiter);
+        assertEq(job.amount, AMOUNT);
+        assertEq(job.feeBps, FEE_BPS);
+        assertEq(uint8(job.status), uint8(FreelanceEscrow.Status.Funded));
+    }
+
+    function test_DeliverThenApprovePaysFreelancerNetOfFee() public {
+        uint256 id = _create();
+
+        vm.prank(freelancer);
+        escrow.deliver(id);
+        assertEq(escrow.getJob(id).reviewDeadline, block.timestamp + REVIEW);
+
+        vm.prank(client);
+        escrow.approve(id);
+
+        uint256 fee = AMOUNT * FEE_BPS / 10_000;
+        assertEq(usdc.balanceOf(freelancer), AMOUNT - fee);
+        assertEq(escrow.feesAccrued(), fee);
+        assertEq(usdc.balanceOf(address(escrow)), fee);
+        assertEq(uint8(escrow.getJob(id).status), uint8(FreelanceEscrow.Status.Complete));
+    }
+
+    function test_ClaimExpiredAfterReviewWindow() public {
+        uint256 id = _create();
+        vm.prank(freelancer);
+        escrow.deliver(id);
+
+        vm.prank(freelancer);
+        vm.expectRevert(FreelanceEscrow.TooEarly.selector);
+        escrow.claimExpired(id);
+
+        vm.warp(block.timestamp + REVIEW + 1);
+        vm.prank(freelancer);
+        escrow.claimExpired(id);
+        assertEq(usdc.balanceOf(freelancer), AMOUNT - AMOUNT * FEE_BPS / 10_000);
+    }
+
+    function test_ReclaimAfterDeliveryDeadline() public {
+        uint256 id = _create();
+
+        vm.prank(client);
+        vm.expectRevert(FreelanceEscrow.TooEarly.selector);
+        escrow.reclaim(id);
+
+        vm.warp(block.timestamp + 30 days + 1);
+        vm.prank(client);
+        escrow.reclaim(id);
+
+        assertEq(usdc.balanceOf(client), 1_000_000e6);
+        assertEq(escrow.feesAccrued(), 0);
+    }
+
+    function test_FreelancerCancelRefundsClient() public {
+        uint256 id = _create();
+        vm.prank(freelancer);
+        escrow.cancel(id);
+        assertEq(usdc.balanceOf(client), 1_000_000e6);
+        assertEq(usdc.balanceOf(freelancer), 0);
+    }
+
+    // ---------------------------------------------------------------- disputes
+
+    function test_DisputeAndResolveSplit() public {
+        uint256 id = _create();
+        vm.prank(freelancer);
+        escrow.deliver(id);
+
+        vm.prank(client);
+        escrow.dispute(id);
+        assertEq(uint8(escrow.getJob(id).status), uint8(FreelanceEscrow.Status.Disputed));
+
+        uint256 award = 6_000e6;
+        vm.prank(arbiter);
+        escrow.resolve(id, award);
+
+        uint256 fee = award * FEE_BPS / 10_000;
+        assertEq(usdc.balanceOf(freelancer), award - fee);
+        assertEq(usdc.balanceOf(client), 1_000_000e6 - AMOUNT + (AMOUNT - award));
+        assertEq(escrow.feesAccrued(), fee);
+    }
+
+    function test_ResolveFullyToClientChargesNoFee() public {
+        uint256 id = _create();
+        vm.prank(freelancer);
+        escrow.dispute(id);
+        vm.prank(arbiter);
+        escrow.resolve(id, 0);
+        assertEq(usdc.balanceOf(client), 1_000_000e6);
+        assertEq(escrow.feesAccrued(), 0);
+    }
+
+    function test_DisputeTooLateAfterReviewWindow() public {
+        uint256 id = _create();
+        vm.prank(freelancer);
+        escrow.deliver(id);
+        vm.warp(block.timestamp + REVIEW + 1);
+
+        vm.prank(client);
+        vm.expectRevert(FreelanceEscrow.TooLate.selector);
+        escrow.dispute(id);
+    }
+
+    function test_DisputeRequiresArbiter() public {
+        vm.prank(client);
+        uint256 id =
+            escrow.createJob(freelancer, address(0), AMOUNT, uint40(block.timestamp + 30 days), REVIEW);
+        vm.prank(client);
+        vm.expectRevert(FreelanceEscrow.NoArbiter.selector);
+        escrow.dispute(id);
+    }
+
+    function test_ResolveCannotExceedEscrowedAmount() public {
+        uint256 id = _create();
+        vm.prank(client);
+        escrow.dispute(id);
+        vm.prank(arbiter);
+        vm.expectRevert(FreelanceEscrow.BadAmount.selector);
+        escrow.resolve(id, AMOUNT + 1);
+    }
+
+    // ------------------------------------------------------------ access control
+
+    function test_OnlyFreelancerCanDeliver() public {
+        uint256 id = _create();
+        vm.prank(client);
+        vm.expectRevert(FreelanceEscrow.NotFreelancer.selector);
+        escrow.deliver(id);
+    }
+
+    function test_OnlyClientCanApprove() public {
+        uint256 id = _create();
+        vm.prank(freelancer);
+        escrow.deliver(id);
+        vm.prank(stranger);
+        vm.expectRevert(FreelanceEscrow.NotClient.selector);
+        escrow.approve(id);
+    }
+
+    function test_OnlyArbiterCanResolve() public {
+        uint256 id = _create();
+        vm.prank(client);
+        escrow.dispute(id);
+        vm.prank(client);
+        vm.expectRevert(FreelanceEscrow.NotArbiter.selector);
+        escrow.resolve(id, 0);
+    }
+
+    function test_StrangerCannotDispute() public {
+        uint256 id = _create();
+        vm.prank(stranger);
+        vm.expectRevert(FreelanceEscrow.NotParty.selector);
+        escrow.dispute(id);
+    }
+
+    function test_CannotDoubleSpendCompletedJob() public {
+        uint256 id = _create();
+        vm.prank(freelancer);
+        escrow.deliver(id);
+        vm.prank(client);
+        escrow.approve(id);
+
+        vm.prank(client);
+        vm.expectRevert(FreelanceEscrow.BadStatus.selector);
+        escrow.approve(id);
+
+        vm.prank(freelancer);
+        vm.expectRevert(FreelanceEscrow.BadStatus.selector);
+        escrow.cancel(id);
+    }
+
+    // ------------------------------------------------------------------ inputs
+
+    function test_RejectsBadJobParameters() public {
+        vm.startPrank(client);
+        vm.expectRevert(FreelanceEscrow.BadAddress.selector);
+        escrow.createJob(address(0), arbiter, AMOUNT, uint40(block.timestamp + 1 days), REVIEW);
+
+        vm.expectRevert(FreelanceEscrow.BadAddress.selector);
+        escrow.createJob(client, arbiter, AMOUNT, uint40(block.timestamp + 1 days), REVIEW);
+
+        vm.expectRevert(FreelanceEscrow.BadAddress.selector);
+        escrow.createJob(freelancer, freelancer, AMOUNT, uint40(block.timestamp + 1 days), REVIEW);
+
+        vm.expectRevert(FreelanceEscrow.BadAmount.selector);
+        escrow.createJob(freelancer, arbiter, 0, uint40(block.timestamp + 1 days), REVIEW);
+
+        vm.expectRevert(FreelanceEscrow.BadDeadline.selector);
+        escrow.createJob(freelancer, arbiter, AMOUNT, uint40(block.timestamp), REVIEW);
+
+        vm.expectRevert(FreelanceEscrow.BadReviewPeriod.selector);
+        escrow.createJob(freelancer, arbiter, AMOUNT, uint40(block.timestamp + 1 days), 1 hours);
+        vm.stopPrank();
+    }
+
+    // -------------------------------------------------------------------- fees
+
+    function test_FeeChangeDoesNotAffectExistingJob() public {
+        uint256 id = _create();
+
+        vm.prank(owner);
+        escrow.setFeeBps(500);
+
+        vm.prank(freelancer);
+        escrow.deliver(id);
+        vm.prank(client);
+        escrow.approve(id);
+
+        assertEq(escrow.feesAccrued(), AMOUNT * FEE_BPS / 10_000);
+    }
+
+    function test_FeeIsCapped() public {
+        vm.prank(owner);
+        vm.expectRevert(FreelanceEscrow.FeeTooHigh.selector);
+        escrow.setFeeBps(501);
+    }
+
+    function test_OnlyOwnerWithdrawsFees() public {
+        uint256 id = _create();
+        vm.prank(freelancer);
+        escrow.deliver(id);
+        vm.prank(client);
+        escrow.approve(id);
+
+        vm.prank(stranger);
+        vm.expectRevert(FreelanceEscrow.NotOwner.selector);
+        escrow.withdrawFees(stranger);
+
+        uint256 fee = AMOUNT * FEE_BPS / 10_000;
+        vm.prank(owner);
+        escrow.withdrawFees(owner);
+        assertEq(usdc.balanceOf(owner), fee);
+        assertEq(escrow.feesAccrued(), 0);
+        assertEq(usdc.balanceOf(address(escrow)), 0);
+    }
+
+    function test_TwoStepOwnershipTransfer() public {
+        vm.prank(owner);
+        escrow.transferOwnership(stranger);
+        assertEq(escrow.owner(), owner);
+
+        vm.prank(stranger);
+        escrow.acceptOwnership();
+        assertEq(escrow.owner(), stranger);
+        assertEq(escrow.pendingOwner(), address(0));
+    }
+
+    // ------------------------------------------------------------ token quirks
+
+    function test_WorksWithTokensThatReturnNothing() public {
+        usdc.setSilentReturn(true);
+        uint256 id = _create();
+        vm.prank(freelancer);
+        escrow.deliver(id);
+        vm.prank(client);
+        escrow.approve(id);
+        assertEq(usdc.balanceOf(freelancer), AMOUNT - AMOUNT * FEE_BPS / 10_000);
+    }
+
+    function test_FailedTokenTransferReverts() public {
+        uint256 id = _create();
+        usdc.setBlocked(freelancer, true);
+        vm.prank(freelancer);
+        escrow.deliver(id);
+        vm.prank(client);
+        vm.expectRevert(FreelanceEscrow.TransferFailed.selector);
+        escrow.approve(id);
+    }
+
+    // --------------------------------------------------------- concurrent jobs
+
+    function test_JobsAreIndependent() public {
+        uint256 a = _create();
+        uint256 b = _create();
+        assertEq(b, a + 1);
+
+        vm.prank(freelancer);
+        escrow.deliver(a);
+        vm.prank(client);
+        escrow.approve(a);
+
+        assertEq(uint8(escrow.getJob(b).status), uint8(FreelanceEscrow.Status.Funded));
+        assertEq(usdc.balanceOf(address(escrow)), AMOUNT + AMOUNT * FEE_BPS / 10_000);
+    }
+
+    // ------------------------------------------------------------------- fuzz
+
+    /// @dev Nothing is ever created or destroyed: escrow always holds exactly the
+    ///      open job amount plus accrued fees.
+    function testFuzz_ConservationOfFunds(uint96 amount, uint16 fee, uint256 award) public {
+        amount = uint96(bound(amount, 1e6, 100_000e6));
+        fee = uint16(bound(fee, 0, escrow.MAX_FEE_BPS()));
+        award = bound(award, 0, amount);
+
+        vm.prank(owner);
+        escrow.setFeeBps(fee);
+
+        vm.prank(client);
+        uint256 id = escrow.createJob(freelancer, arbiter, amount, uint40(block.timestamp + 30 days), REVIEW);
+
+        vm.prank(client);
+        escrow.dispute(id);
+        vm.prank(arbiter);
+        escrow.resolve(id, award);
+
+        uint256 feeTaken = award * fee / 10_000;
+        assertEq(usdc.balanceOf(freelancer), award - feeTaken);
+        assertEq(usdc.balanceOf(client), 1_000_000e6 - award);
+        assertEq(usdc.balanceOf(address(escrow)), feeTaken);
+        assertEq(escrow.feesAccrued(), feeTaken);
+    }
+}
