+++ b/src/FreelanceEscrow.sol
@@ -0,0 +1,376 @@
+// SPDX-License-Identifier: MIT
+pragma solidity 0.8.28;
+
+/// @notice Minimal subset of the ERC-20 interface used by the escrow.
+interface IERC20 {
+    function transfer(address to, uint256 value) external returns (bool);
+    function transferFrom(address from, address to, uint256 value) external returns (bool);
+    function decimals() external view returns (uint8);
+}
+
+/**
+ * @title FreelanceEscrow
+ * @notice Holds a stablecoin payment for a single freelance job until the work is
+ *         accepted, the review window lapses, the delivery deadline passes, or an
+ *         arbiter splits the funds.
+ *
+ * Lifecycle
+ *
+ *   createJob()  ──> Funded ──deliver()──> Delivered ──approve()────────> Complete
+ *                      │                       │      └─claimExpired()──> Complete
+ *                      │                       │
+ *                      ├─reclaim()  (after delivery deadline)───────────> Complete
+ *                      ├─cancel()   (freelancer walks away)─────────────> Complete
+ *                      │                       │
+ *                      └─────dispute()─────────┴──> Disputed ─resolve()─> Complete
+ *
+ * Design notes
+ * - One deployment serves one token. The token is fixed at construction so job
+ *   accounting never has to trust a caller-supplied token address.
+ * - The protocol fee is snapshotted per job at creation. Raising the fee later
+ *   cannot change the payout of a job that is already funded.
+ * - Fees accrue inside the contract and are withdrawn separately, so a failing
+ *   fee transfer can never block a freelancer's payout.
+ * - The contract holds no ETH and has no `receive` function.
+ */
+contract FreelanceEscrow {
+    // ---------------------------------------------------------------- types
+
+    enum Status {
+        None,
+        Funded,
+        Delivered,
+        Disputed,
+        Complete
+    }
+
+    struct Job {
+        // slot 0
+        address client;
+        uint96 amount;
+        // slot 1
+        address freelancer;
+        uint16 feeBps;
+        uint40 deliveryDeadline;
+        uint32 reviewPeriod;
+        Status status;
+        // slot 2
+        address arbiter;
+        uint40 reviewDeadline;
+    }
+
+    // ------------------------------------------------------------ constants
+
+    uint16 public constant MAX_FEE_BPS = 500; // 5%
+    uint32 public constant MIN_REVIEW_PERIOD = 1 days;
+    uint32 public constant MAX_REVIEW_PERIOD = 30 days;
+    uint40 public constant MAX_DELIVERY_TERM = 365 days;
+
+    IERC20 public immutable token;
+
+    // ------------------------------------------------------------- storage
+
+    address public owner;
+    address public pendingOwner;
+    uint16 public feeBps;
+    uint256 public feesAccrued;
+
+    uint256 public nextJobId = 1;
+    mapping(uint256 => Job) private _jobs;
+
+    // -------------------------------------------------------------- events
+
+    event JobCreated(
+        uint256 indexed jobId,
+        address indexed client,
+        address indexed freelancer,
+        address arbiter,
+        uint256 amount,
+        uint16 feeBps,
+        uint40 deliveryDeadline,
+        uint32 reviewPeriod
+    );
+    event Delivered(uint256 indexed jobId, uint40 reviewDeadline);
+    event Released(uint256 indexed jobId, address indexed to, uint256 paid, uint256 fee);
+    event Refunded(uint256 indexed jobId, address indexed to, uint256 amount);
+    event Disputed(uint256 indexed jobId, address indexed by);
+    event Resolved(uint256 indexed jobId, uint256 toFreelancer, uint256 toClient, uint256 fee);
+    event FeeUpdated(uint16 oldFeeBps, uint16 newFeeBps);
+    event FeesWithdrawn(address indexed to, uint256 amount);
+    event OwnershipTransferStarted(address indexed from, address indexed to);
+    event OwnershipTransferred(address indexed from, address indexed to);
+
+    // -------------------------------------------------------------- errors
+
+    error NotOwner();
+    error NotClient();
+    error NotFreelancer();
+    error NotArbiter();
+    error NotParty();
+    error BadStatus();
+    error BadAddress();
+    error BadAmount();
+    error BadDeadline();
+    error BadReviewPeriod();
+    error FeeTooHigh();
+    error NoArbiter();
+    error TooEarly();
+    error TooLate();
+    error Reentrancy();
+    error TransferFailed();
+
+    // -------------------------------------------------------------- guards
+
+    uint256 private _lock = 1;
+
+    modifier nonReentrant() {
+        if (_lock != 1) revert Reentrancy();
+        _lock = 2;
+        _;
+        _lock = 1;
+    }
+
+    modifier onlyOwner() {
+        if (msg.sender != owner) revert NotOwner();
+        _;
+    }
+
+    // --------------------------------------------------------- constructor
+
+    /// @param token_ Payment token. Use a 6-decimal stablecoin such as USDC.
+    /// @param owner_ Fee recipient and fee administrator.
+    /// @param feeBps_ Initial protocol fee in basis points, at most MAX_FEE_BPS.
+    constructor(address token_, address owner_, uint16 feeBps_) {
+        if (token_ == address(0) || owner_ == address(0)) revert BadAddress();
+        if (feeBps_ > MAX_FEE_BPS) revert FeeTooHigh();
+        token = IERC20(token_);
+        owner = owner_;
+        feeBps = feeBps_;
+        emit OwnershipTransferred(address(0), owner_);
+    }
+
+    // ----------------------------------------------------------- job flow
+
+    /**
+     * @notice Fund a new job. The caller becomes the client and must have approved
+     *         `amount` of the payment token to this contract.
+     * @param freelancer Who gets paid when the work is accepted.
+     * @param arbiter Who resolves a dispute. Pass address(0) to disable disputes.
+     * @param amount Escrowed amount in token units.
+     * @param deliveryDeadline Unix time after which the client can reclaim the funds.
+     * @param reviewPeriod Seconds the client has to accept or dispute after delivery.
+     * @return jobId Identifier of the new job.
+     */
+    function createJob(
+        address freelancer,
+        address arbiter,
+        uint256 amount,
+        uint40 deliveryDeadline,
+        uint32 reviewPeriod
+    ) external nonReentrant returns (uint256 jobId) {
+        if (freelancer == address(0) || freelancer == msg.sender) {
+            revert BadAddress();
+        }
+        if (arbiter == msg.sender || arbiter == freelancer) revert BadAddress();
+        if (amount == 0 || amount > type(uint96).max) revert BadAmount();
+        if (deliveryDeadline <= block.timestamp) revert BadDeadline();
+        if (deliveryDeadline > block.timestamp + MAX_DELIVERY_TERM) revert BadDeadline();
+        if (reviewPeriod < MIN_REVIEW_PERIOD || reviewPeriod > MAX_REVIEW_PERIOD) {
+            revert BadReviewPeriod();
+        }
+
+        jobId = nextJobId++;
+        uint16 fee = feeBps;
+
+        _jobs[jobId] = Job({
+            client: msg.sender,
+            amount: uint96(amount),
+            freelancer: freelancer,
+            feeBps: fee,
+            deliveryDeadline: deliveryDeadline,
+            reviewPeriod: reviewPeriod,
+            status: Status.Funded,
+            arbiter: arbiter,
+            reviewDeadline: 0
+        });
+
+        emit JobCreated(jobId, msg.sender, freelancer, arbiter, amount, fee, deliveryDeadline, reviewPeriod);
+
+        _pull(msg.sender, amount);
+    }
+
+    /// @notice Freelancer marks the work delivered, which starts the client's review window.
+    function deliver(uint256 jobId) external {
+        Job storage job = _jobs[jobId];
+        if (job.status != Status.Funded) revert BadStatus();
+        if (msg.sender != job.freelancer) revert NotFreelancer();
+
+        uint40 reviewDeadline = uint40(block.timestamp) + uint40(job.reviewPeriod);
+        job.status = Status.Delivered;
+        job.reviewDeadline = reviewDeadline;
+
+        emit Delivered(jobId, reviewDeadline);
+    }
+
+    /// @notice Client accepts the work and releases payment to the freelancer.
+    function approve(uint256 jobId) external nonReentrant {
+        Job storage job = _jobs[jobId];
+        if (job.status != Status.Delivered) revert BadStatus();
+        if (msg.sender != job.client) revert NotClient();
+        _release(jobId, job);
+    }
+
+    /// @notice Freelancer takes payment because the client let the review window lapse.
+    function claimExpired(uint256 jobId) external nonReentrant {
+        Job storage job = _jobs[jobId];
+        if (job.status != Status.Delivered) revert BadStatus();
+        if (msg.sender != job.freelancer) revert NotFreelancer();
+        if (block.timestamp <= job.reviewDeadline) revert TooEarly();
+        _release(jobId, job);
+    }
+
+    /// @notice Client reclaims the funds because nothing was delivered by the deadline.
+    function reclaim(uint256 jobId) external nonReentrant {
+        Job storage job = _jobs[jobId];
+        if (job.status != Status.Funded) revert BadStatus();
+        if (msg.sender != job.client) revert NotClient();
+        if (block.timestamp <= job.deliveryDeadline) revert TooEarly();
+
+        address client = job.client;
+        uint256 amount = job.amount;
+        job.status = Status.Complete;
+
+        emit Refunded(jobId, client, amount);
+        _push(client, amount);
+    }
+
+    /// @notice Freelancer walks away from the job and returns the full amount to the client.
+    function cancel(uint256 jobId) external nonReentrant {
+        Job storage job = _jobs[jobId];
+        if (job.status != Status.Funded && job.status != Status.Delivered) revert BadStatus();
+        if (msg.sender != job.freelancer) revert NotFreelancer();
+
+        address client = job.client;
+        uint256 amount = job.amount;
+        job.status = Status.Complete;
+
+        emit Refunded(jobId, client, amount);
+        _push(client, amount);
+    }
+
+    /**
+     * @notice Either party escalates the job to the arbiter, freezing the funds until
+     *         `resolve` is called. The client must dispute before the review window ends.
+     */
+    function dispute(uint256 jobId) external {
+        Job storage job = _jobs[jobId];
+        Status status = job.status;
+        if (status != Status.Funded && status != Status.Delivered) revert BadStatus();
+        if (msg.sender != job.client && msg.sender != job.freelancer) revert NotParty();
+        if (job.arbiter == address(0)) revert NoArbiter();
+        if (status == Status.Delivered && block.timestamp > job.reviewDeadline) revert TooLate();
+
+        job.status = Status.Disputed;
+        emit Disputed(jobId, msg.sender);
+    }
+
+    /**
+     * @notice Arbiter splits a disputed job. The protocol fee applies only to the
+     *         freelancer's share; the client's share is refunded in full.
+     * @param toFreelancer Gross amount awarded to the freelancer, at most the escrowed amount.
+     */
+    function resolve(uint256 jobId, uint256 toFreelancer) external nonReentrant {
+        Job storage job = _jobs[jobId];
+        if (job.status != Status.Disputed) revert BadStatus();
+        if (msg.sender != job.arbiter) revert NotArbiter();
+
+        uint256 amount = job.amount;
+        if (toFreelancer > amount) revert BadAmount();
+
+        uint256 fee = (toFreelancer * job.feeBps) / 10_000;
+        uint256 freelancerPayout = toFreelancer - fee;
+        uint256 clientPayout = amount - toFreelancer;
+
+        address freelancer = job.freelancer;
+        address client = job.client;
+        job.status = Status.Complete;
+
+        if (fee != 0) feesAccrued += fee;
+        emit Resolved(jobId, freelancerPayout, clientPayout, fee);
+
+        if (freelancerPayout != 0) _push(freelancer, freelancerPayout);
+        if (clientPayout != 0) _push(client, clientPayout);
+    }
+
+    // ---------------------------------------------------------------- views
+
+    function getJob(uint256 jobId) external view returns (Job memory) {
+        return _jobs[jobId];
+    }
+
+    /// @notice Amount the freelancer receives and the fee taken, for a job's full amount.
+    function quote(uint256 jobId) external view returns (uint256 payout, uint256 fee) {
+        Job storage job = _jobs[jobId];
+        uint256 amount = job.amount;
+        fee = (amount * job.feeBps) / 10_000;
+        payout = amount - fee;
+    }
+
+    // ------------------------------------------------------------- admin
+
+    function setFeeBps(uint16 newFeeBps) external onlyOwner {
+        if (newFeeBps > MAX_FEE_BPS) revert FeeTooHigh();
+        emit FeeUpdated(feeBps, newFeeBps);
+        feeBps = newFeeBps;
+    }
+
+    function withdrawFees(address to) external onlyOwner nonReentrant {
+        if (to == address(0)) revert BadAddress();
+        uint256 amount = feesAccrued;
+        if (amount == 0) revert BadAmount();
+        feesAccrued = 0;
+        emit FeesWithdrawn(to, amount);
+        _push(to, amount);
+    }
+
+    function transferOwnership(address newOwner) external onlyOwner {
+        pendingOwner = newOwner;
+        emit OwnershipTransferStarted(owner, newOwner);
+    }
+
+    function acceptOwnership() external {
+        if (msg.sender != pendingOwner) revert NotOwner();
+        emit OwnershipTransferred(owner, msg.sender);
+        owner = msg.sender;
+        pendingOwner = address(0);
+    }
+
+    // ---------------------------------------------------------- internals
+
+    function _release(uint256 jobId, Job storage job) private {
+        uint256 amount = job.amount;
+        uint256 fee = (amount * job.feeBps) / 10_000;
+        uint256 payout = amount - fee;
+        address freelancer = job.freelancer;
+
+        job.status = Status.Complete;
+        if (fee != 0) feesAccrued += fee;
+
+        emit Released(jobId, freelancer, payout, fee);
+        _push(freelancer, payout);
+    }
+
+    function _pull(address from, uint256 amount) private {
+        _call(abi.encodeCall(IERC20.transferFrom, (from, address(this), amount)));
+    }
+
+    function _push(address to, uint256 amount) private {
+        _call(abi.encodeCall(IERC20.transfer, (to, amount)));
+    }
+
+    /// @dev Handles tokens that return no value on success, such as USDT.
+    function _call(bytes memory data) private {
+        (bool ok, bytes memory ret) = address(token).call(data);
+        if (!ok || (ret.length != 0 && !abi.decode(ret, (bool)))) revert TransferFailed();
+    }
+}
